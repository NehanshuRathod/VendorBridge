# ============================================
# VendorBridge ERP — Environment Variables
# ============================================

# PostgreSQL
POSTGRES_DB=vendorbridge
POSTGRES_USER=vendorbridge
POSTGRES_PASSWORD=vendorbridge_secret
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/vendorbridge
SPRING_DATASOURCE_USERNAME=vendorbridge
SPRING_DATASOURCE_PASSWORD=vendorbridge_secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=vendorbridge
RABBITMQ_PASSWORD=rabbitmq_secret

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET_NAME=vendorbridge

# JWT
JWT_SECRET=ThisIsAVeryLongSecretKeyForVendorBridgeJWTTokenGenerationMustBeAtLeast64Characters!!
JWT_ACCESS_TOKEN_EXPIRY=900000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@vendorbridge.com

# Spring
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
